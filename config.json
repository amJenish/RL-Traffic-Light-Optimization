{
  "_comment": "Single source of truth for main.py. Paths are relative to the project root unless absolute. Reward/policy hyperparameters: reward_configuration.json and policy_configuration.json. Class selection: components.reward_class / components.policy_class.",

  "paths": {
    "csv": "src/data/synthetic_toronto_data.csv",
    "intersection": "src/intersection.json",
    "columns": "src/columns.json",
    "reward_configuration": "modelling/components/reward/reward_configuration.json",
    "policy_configuration": "modelling/components/policy/policy_configuration.json",
    "sumo_home": ""
  },

  "training": {
    "n_epochs": 200,
    "train_days": 1,
    "test_days": 5,
    "save_every": 999,
    "log_every": 1,
    "seed": 42,
    "lr_min": 0.0001,
    "scheduler": "cosine",
    "decisions_per_ep_divisor": 2
  },

  "simulation": {
    "step_length": 1.0,
    "decision_gap": 10,
    "begin": 28800,
    "end": 36000,
    "gui": false
  },

  "phase_timing": {
    "min_green_s": 15,
    "max_green_s": 90,
    "overshoot_coeff": 1.0,
    "yellow_duration_s": 4.0
  },

  "observation": {
    "max_lanes": 16,
    "max_phase": 7,
    "max_phase_time": 120.0,
    "max_vehicles": 20
  },

  "components": {
    "reward_class": "WaitingTimeReward",
    "policy_class": "DoubleDQNPolicy"
  },

  "policy": {
    "learning_rate": 0.01,
    "gamma": 0.95,
    "epsilon_start": 1.0,
    "epsilon_end": 0.05,
    "epsilon_decay": 0.99998415,
    "target_update": 50,
    "batch_size": 128,
    "hidden": 256
  },

  "replay_buffer": {
    "capacity": 8000
  },

  "output": {
    "out_dir": "src/data",
    "results_dir": "src/data/results",
    "result_graphs_dir": "src/data/result_graphs",
    "models_dir": "src/data/models"
  }
}
